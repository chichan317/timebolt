# OPTIONAL extra protection. The data file already self-protects (it's a .php
# file starting with "<?php exit;"), so uploading this .htaccess is not required
# — it's just defense in depth on Apache hosts like SiteGround.
<FilesMatch "\.store\.php$">
  Require all denied
</FilesMatch>

# Fallback for older Apache (2.2).
<IfModule !mod_authz_core.c>
  <FilesMatch "\.store\.php$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>
